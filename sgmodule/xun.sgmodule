#!name=Xunlei VIP + 302 Optimizer
#!desc=Optimize Xunlei VIP playback + 302 redirect + fallback stability (no MITM required)
#!author=ChatGPT

[General]
always-raw-tcp = true
loglevel = notify



[Header Rewrite]

# UA伪装（提升302成功率）
^https?:\/\/.*xunlei.* url-request-header User-Agent: Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Mobile/15E148 Safari/604.1

# Referer修复
^https?:\/\/.*xunlei.* url-request-header Referer: https://xunlei.com

# Range优化（视频分段）
^https?:\/\/.*xunlei.* url-request-header Range: bytes=0-
